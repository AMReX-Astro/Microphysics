@namespace: unit_test

# the final time to integrate to
tmax          real       1.e-2

# first output time -- we will output in nsteps logarithmically spaced steps between [tfirst, tmax]
tfirst        real       0.0

# number of steps (logarithmically spaced)
nsteps        int    100

# If true, use a continuous VODE solve across output times (single
# solver session) instead of restarting for each output interval.
vode_continuation_mode    bool    0

density       real       1.e7

temperature   real       3.e9

skip_initial_normalization    bool    0
